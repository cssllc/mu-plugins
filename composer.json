{
    "name": "cssllc/mu-plugins",
    "description": "CSSLLC MU-Plugins",
    "require-dev": {
        "automattic/vipwpcs": "*",
        "szepeviktor/phpstan-wordpress": "*",
        "phpstan/extension-installer": "*",
        "php-stubs/acf-pro-stubs": "*",
        "php-stubs/wordpress-stubs": "*",
        "squizlabs/php_codesniffer": "*",
        "mediawiki/mediawiki-codesniffer": "*",
        "php-stubs/wp-cli-stubs": "*",
        "phpcompatibility/php-compatibility": "*",
        "symplify/vendor-patches": "*"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "cweagans/composer-patches": true
        }
    },
    "license": "proprietary",
    "extra": {
        "patches": {
            "php-stubs/acf-pro-stubs": [
                "dev/patches/php-stubs-acf-pro-stubs-acf-pro-stubs-php.patch"
            ]
        }
    },
    "scripts": {
        "phpcs": "./vendor/bin/phpcs -s --standard=phpcs.xml",
        "phpstan": "./vendor/bin/phpstan --configuration=phpstan.neon --memory-limit=-1"
    }
}
